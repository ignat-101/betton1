# Адрес админ-кошелька (обязательно для админских эндпоинтов)
ADMIN_WALLET=UQCfdyrb0Fj8lA32OfizTwGY829tTzihsEYl1FrpBzeVKdi0

# Казна для депозитов (TON отправляются сюда)
TREASURY_WALLET=UQCfdyrb0Fj8lA32OfizTwGY829tTzihsEYl1FrpBzeVKdi0

# URL сервиса подписи выплат (POST /sign {to, amount, payout_id} -> {tx_hash})
# Локальный mock: http://localhost:3001/sign
PAYOUT_SIGNER_URL=

# URL сервиса верификации депозитов (POST /verify {tx_hash} -> {valid, to, amount})
DEPOSIT_VERIFIER_URL=

# Автоматическое одобрение депозитов (ОПАСНО без verifier!)
AUTO_APPROVE_DEPOSITS=false

# Автоматическая отправка выплат через signer
AUTO_SEND_PAYOUTS=false

# TON API ключ для авто-сканирования депозитов (опционально)
TON_API_KEY=

# Порт для Render (не трогать)
PORT=10000

# Для production на Render замените значения на свои!
