# TON betton Backend Configuration
# Copy this file to .env and update values for your environment

# Server
PORT=5000

# Admin & Treasury
ADMIN_WALLET=UQCfdyrb0Fj8lA32OfizTwGY829tTzihsEYl1FrpBzeVKdi0
TREASURY_WALLET=UQCfdyrb0Fj8lA32OfizTwGY829tTzihsEYl1FrpBzeVKdi0

# External Services (Payout & Deposit Verification)
# These should point to secure signing and verification services
PAYOUT_SIGNER_URL=https://your-signer-service.onrender.com/sign
DEPOSIT_VERIFIER_URL=https://your-verifier-service.onrender.com/verify

# Auto Approval (set to 'true' for development, 'false' for production)
